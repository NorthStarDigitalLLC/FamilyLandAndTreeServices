<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Premium Modern Website</title>
  <meta name="description" content="A premium modern website template that works as a single HTML file." />
  <style>
    :root{
      --bg:#0b1020;
      --bg2:#111936;
      --card:rgba(255,255,255,0.08);
      --line:rgba(255,255,255,0.12);
      --text:#f5f7ff;
      --muted:#b7c0e0;
      --accent:#7c5cff;
      --accent2:#21d4fd;
      --gold:#f5c76b;
      --shadow:0 20px 60px rgba(0,0,0,.35);
      --radius:22px;
      --max:1180px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 10% 10%, rgba(124,92,255,.28), transparent 28%),
        radial-gradient(circle at 90% 20%, rgba(33,212,253,.16), transparent 24%),
        radial-gradient(circle at 70% 85%, rgba(245,199,107,.12), transparent 22%),
        linear-gradient(180deg, var(--bg), var(--bg2));
      min-height:100vh;
      overflow-x:hidden;
    }

    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}
    .container{width:min(var(--max), calc(100% - 32px));margin:0 auto}
    .section{padding:88px 0}
    .eyebrow{
      display:inline-flex;align-items:center;gap:10px;
      padding:10px 14px;border:1px solid var(--line);
      border-radius:999px;background:rgba(255,255,255,.05);
      color:#d8def7;font-size:13px;letter-spacing:.12em;text-transform:uppercase
    }
    .eyebrow::before{
      content:"";width:8px;height:8px;border-radius:50%;
      background:linear-gradient(135deg,var(--gold),#fff0bf)
    }
    .btn{
      display:inline-flex;align-items:center;justify-content:center;gap:10px;
      padding:14px 18px;border-radius:14px;border:1px solid transparent;
      font-weight:700;transition:.25s ease;cursor:pointer
    }
    .btn-primary{
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      box-shadow:0 16px 36px rgba(124,92,255,.25)
    }
    .btn-primary:hover{transform:translateY(-2px);filter:saturate(1.08)}
    .btn-secondary{
      background:rgba(255,255,255,.06);
      border-color:var(--line);backdrop-filter:blur(12px)
    }
    .btn-secondary:hover{background:rgba(255,255,255,.1)}
    .grid{display:grid;gap:22px}

    /* Header */
    header{
      position:sticky;top:0;z-index:1000;
      backdrop-filter:blur(16px);
      background:linear-gradient(180deg, rgba(5,8,18,.72), rgba(5,8,18,.32));
      border-bottom:1px solid rgba(255,255,255,.08)
    }
    .nav{
      height:78px;display:flex;align-items:center;justify-content:space-between
    }
    .brand{
      display:flex;align-items:center;gap:12px;font-weight:800;letter-spacing:.02em
    }
    .brand-mark{
      width:40px;height:40px;border-radius:14px;
      background:linear-gradient(135deg,var(--accent),var(--accent2));
      position:relative;box-shadow:var(--shadow)
    }
    .brand-mark::after{
      content:"";position:absolute;inset:2px;border-radius:12px;
      border:1px solid rgba(255,255,255,.35)
    }
    nav ul{
      display:flex;align-items:center;gap:26px;list-style:none;margin:0;padding:0
    }
    nav a{color:#dbe2ff}
    nav a:hover{color:#fff}
    .menu-btn{
      display:none;background:none;border:none;color:#fff;font-size:28px;cursor:pointer
    }

    /* Hero */
    .hero{padding:56px 0 28px}
    .hero-wrap{
      display:grid;grid-template-columns:1.12fr .88fr;gap:28px;align-items:center
    }
    .hero h1{
      margin:18px 0 14px;
      font-size:clamp(40px, 7vw, 78px);
      line-height:.96;letter-spacing:-.04em
    }
    .hero p{
      color:var(--muted);font-size:18px;line-height:1.7;max-width:680px
    }
    .hero-actions{display:flex;flex-wrap:wrap;gap:14px;margin-top:28px}
    .metrics{
      margin-top:26px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px;max-width:760px
    }
    .metric{
      padding:18px;border:1px solid var(--line);
      background:rgba(255,255,255,.05);border-radius:18px;backdrop-filter:blur(10px)
    }
    .metric strong{display:block;font-size:28px}
    .metric span{color:var(--muted);font-size:14px}
    .hero-card{
      position:relative;min-height:560px;border-radius:30px;overflow:hidden;
      border:1px solid rgba(255,255,255,.14);
      background:
        radial-gradient(circle at 25% 20%, rgba(124,92,255,.34), transparent 34%),
        radial-gradient(circle at 75% 28%, rgba(33,212,253,.2), transparent 28%),
        linear-gradient(180deg, rgba(255,255,255,.1), rgba(255,255,255,.03));
      box-shadow:var(--shadow)
    }
    .orb{
      position:absolute;border-radius:999px;filter:blur(4px)
    }
    .orb.one{width:220px;height:220px;background:rgba(124,92,255,.34);top:42px;right:42px}
    .orb.two{width:180px;height:180px;background:rgba(33,212,253,.24);bottom:54px;left:42px}
    .floating{
      position:absolute;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);
      backdrop-filter:blur(16px);border-radius:22px;box-shadow:var(--shadow)
    }
    .f1{top:34px;left:30px;width:240px;padding:18px}
    .f2{top:170px;right:22px;width:260px;padding:18px}
    .f3{bottom:30px;left:28px;right:28px;padding:20px}
    .floating h4{margin:0 0 10px;font-size:14px;color:#dfe5ff;text-transform:uppercase;letter-spacing:.12em}
    .floating p{margin:0;color:#eef2ff;line-height:1.6;font-size:15px}
    .chart{
      height:120px;border-radius:16px;margin-top:14px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.1), rgba(255,255,255,.03)),
        repeating-linear-gradient(90deg, transparent 0 18px, rgba(255,255,255,.05) 18px 19px),
        repeating-linear-gradient(180deg, transparent 0 22px, rgba(255,255,255,.05) 22px 23px);
      position:relative;overflow:hidden
    }
    .chart::after{
      content:"";position:absolute;left:8px;right:8px;top:20px;bottom:18px;
      background:linear-gradient(180deg, rgba(124,92,255,.18), rgba(33,212,253,.12));
      clip-path:polygon(0% 82%, 10% 74%, 20% 77%, 30% 64%, 40% 68%, 50% 46%, 60% 54%, 70% 34%, 80% 38%, 90% 20%, 100% 10%, 100% 100%, 0% 100%)
    }

    /* Logos */
    .logos{
      display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-top:26px
    }
    .logo-box{
      padding:18px;border-radius:18px;border:1px solid var(--line);
      background:rgba(255,255,255,.05);text-align:center;color:#dbe2ff;font-weight:700
    }

    /* Cards */
    .card{
      background:var(--card);border:1px solid var(--line);
      border-radius:var(--radius);padding:24px;backdrop-filter:blur(12px);box-shadow:var(--shadow)
    }
    .card h3{margin:10px 0 10px;font-size:24px}
    .card p{margin:0;color:var(--muted);line-height:1.75}

    .services{grid-template-columns:repeat(3,1fr)}
    .icon{
      width:54px;height:54px;border-radius:16px;display:grid;place-items:center;
      background:linear-gradient(135deg, rgba(124,92,255,.28), rgba(33,212,253,.22));
      border:1px solid rgba(255,255,255,.12);font-size:22px
    }

    .split{
      display:grid;grid-template-columns:1fr 1fr;gap:26px;align-items:center
    }
    .panel{
      border-radius:28px;padding:28px;border:1px solid var(--line);
      background:rgba(255,255,255,.05);box-shadow:var(--shadow)
    }

    .checklist{display:grid;gap:14px;margin-top:20px}
    .check{
      display:flex;gap:12px;align-items:flex-start;padding:14px 16px;border-radius:16px;
      border:1px solid var(--line);background:rgba(255,255,255,.04)
    }
    .check b{display:block;margin-bottom:4px}
    .check span{color:var(--muted);font-size:15px;line-height:1.65}

    .showcase{grid-template-columns:repeat(3,1fr)}
    .showcase .card{overflow:hidden;padding:0}
    .thumb{
      height:220px;
      background:
        radial-gradient(circle at 20% 20%, rgba(124,92,255,.34), transparent 28%),
        radial-gradient(circle at 75% 30%, rgba(33,212,253,.24), transparent 24%),
        linear-gradient(135deg, #121938, #1a2552 55%, #0d132d);
      position:relative
    }
    .thumb::after{
      content:"";position:absolute;inset:24px;border-radius:18px;
      border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06)
    }
    .showcase .content{padding:22px}

    .pricing{grid-template-columns:repeat(3,1fr)}
    .price{
      font-size:46px;font-weight:900;letter-spacing:-.03em;margin:10px 0
    }
    .price small{font-size:16px;color:var(--muted);font-weight:600}
    .list{display:grid;gap:12px;margin:18px 0 24px;padding:0;list-style:none}
    .list li{
      padding:12px 0;border-bottom:1px dashed rgba(255,255,255,.12);color:#dfe5ff
    }
    .featured{
      outline:2px solid rgba(245,199,107,.45);
      transform:translateY(-10px)
    }

    .testimonials{grid-template-columns:repeat(3,1fr)}
    .quote{font-size:18px;line-height:1.8;color:#eef2ff}
    .person{margin-top:18px;color:var(--muted);font-weight:600}

    .faq{max-width:900px;margin:0 auto}
    details{
      border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.05);
      padding:18px 20px
    }
    details + details{margin-top:14px}
    summary{cursor:pointer;font-weight:800}
    details p{color:var(--muted);line-height:1.8;margin:14px 0 0}

    .cta{
      position:relative;overflow:hidden;text-align:center
    }
    .cta::before{
      content:"";position:absolute;inset:-40%;
      background:radial-gradient(circle, rgba(124,92,255,.16), transparent 35%);
      animation:spin 18s linear infinite
    }
    @keyframes spin{to{transform:rotate(360deg)}}
    .cta .inner{position:relative;z-index:1}

    footer{
      border-top:1px solid rgba(255,255,255,.08);
      padding:26px 0 46px;color:var(--muted)
    }
    .footer-row{
      display:flex;justify-content:space-between;gap:18px;align-items:center;flex-wrap:wrap
    }

    /* reveal */
    .reveal{opacity:0;transform:translateY(24px);transition:.7s ease}
    .reveal.visible{opacity:1;transform:none}

    /* mobile */
    @media (max-width: 980px){
      .hero-wrap,.split,.services,.showcase,.pricing,.testimonials{grid-template-columns:1fr}
      .logos{grid-template-columns:repeat(2,1fr)}
      .metrics{grid-template-columns:1fr}
      nav ul{
        position:absolute;left:16px;right:16px;top:88px;display:none;flex-direction:column;
        padding:18px;border:1px solid var(--line);border-radius:20px;
        background:rgba(10,14,28,.94);backdrop-filter:blur(16px)
      }
      nav ul.open{display:flex}
      .menu-btn{display:block}
      .nav-actions{display:none}
    }
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <a href="#top" class="brand">
        <span class="brand-mark"></span>
        <span>Northstar Studio</span>
      </a>

      <nav>
        <button class="menu-btn" id="menuBtn" aria-label="Open menu">☰</button>
        <ul id="navList">
          <li><a href="#services">Services</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#work">Work</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>

      <div class="nav-actions">
        <a class="btn btn-secondary" href="#work">View Work</a>
      </div>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="container hero-wrap">
        <div class="reveal visible">
          <span class="eyebrow">Premium Web Design</span>
          <h1>Modern websites that feel expensive the moment they load.</h1>
          <p>
            This is a fully working single-file website. No frameworks. No package installs.
            No broken dependencies. Save it as <strong>index.html</strong> and open it in your browser.
            Then swap in your business name, text, photos, and links.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="btn btn-primary">Start Your Project</a>
            <a href="#services" class="btn btn-secondary">Explore Services</a>
          </div>

          <div class="metrics">
            <div class="metric">
              <strong>10+</strong>
              <span>Premium sections included</span>
            </div>
            <div class="metric">
              <strong>100%</strong>
              <span>Plain HTML/CSS/JS</span>
            </div>
            <div class="metric">
              <strong>0</strong>
              <span>Dependencies required</span>
            </div>
          </div>

          <div class="logos">
            <div class="logo-box">Luxury</div>
            <div class="logo-box">Agency</div>
            <div class="logo-box">SaaS</div>
            <div class="logo-box">Portfolio</div>
            <div class="logo-box">Brand</div>
          </div>
        </div>

        <div class="hero-card reveal">
          <div class="orb one"></div>
          <div class="orb two"></div>

          <div class="floating f1">
            <h4>Design System</h4>
            <p>Elegant spacing, rounded cards, glassmorphism layers, and high-end typography for a premium feel.</p>
          </div>

          <div class="floating f2">
            <h4>Conversion Ready</h4>
            <p>Built with clear calls to action, pricing, testimonials, and FAQ to turn visits into inquiries.</p>
            <div class="chart"></div>
          </div>

          <div class="floating f3">
            <h4>Why this works</h4>
            <p>This file contains everything in one place, so it will open correctly in any browser as long as it is saved as <strong>index.html</strong>.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container grid services" id="services">
        <article class="card reveal">
          <div class="icon">✦</div>
          <h3>Premium Branding</h3>
          <p>Luxury visual direction, polished layouts, and refined typography that instantly elevate trust and perceived value.</p>
        </article>
        <article class="card reveal">
          <div class="icon">⚡</div>
          <h3>Fast Performance</h3>
          <p>Single-file architecture keeps setup simple and reduces the chance of broken files or missing build steps.</p>
        </article>
        <article class="card reveal">
          <div class="icon">◎</div>
          <h3>Responsive Design</h3>
          <p>Optimized sections adapt cleanly from desktop to mobile with a collapsible menu and stacked content blocks.</p>
        </article>
      </div>
    </section>

    <section class="section" id="about">
      <div class="container split">
        <div class="panel reveal">
          <span class="eyebrow">About This Template</span>
          <h2 style="font-size:clamp(30px,4vw,52px);line-height:1.05;margin:18px 0 14px">A clean premium foundation you can actually launch.</h2>
          <p style="color:var(--muted);line-height:1.8;font-size:17px">
            If your last files showed code on the page, the most common cause is that the file was pasted into the wrong place
            or saved as a text document instead of an HTML document. This template avoids that problem by keeping everything in one file.
          </p>
          <div class="checklist">
            <div class="check">
              <div>✓</div>
              <div><b>Save as index.html</b><span>Do not save it as .txt or paste it into a page builder text block.</span></div>
            </div>
            <div class="check">
              <div>✓</div>
              <div><b>Open directly in browser</b><span>Double-click the file after saving it to confirm it renders as a website.</span></div>
            </div>
            <div class="check">
              <div>✓</div>
              <div><b>Upload exactly as-is</b><span>For GitHub Pages, put this file at the root of your repository.</span></div>
            </div>
          </div>
        </div>

        <div class="panel reveal">
          <div class="card" style="padding:0;overflow:hidden">
            <div class="thumb"></div>
            <div class="content" style="padding:24px">
              <h3 style="margin-top:0">What to edit first</h3>
              <p>Change the brand name, headline, paragraph text, services, pricing, testimonials, and contact info. You can also replace colors in the CSS variables near the top of the file.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="work">
      <div class="container">
        <div class="reveal">
          <span class="eyebrow">Featured Work</span>
          <h2 style="font-size:clamp(30px,4vw,52px);line-height:1.05;margin:18px 0 14px">Layouts designed to impress from the first scroll.</h2>
          <p style="color:var(--muted);max-width:780px;line-height:1.8">
            Use these cards as portfolio items, featured services, product pages, or case studies.
          </p>
        </div>

        <div class="grid showcase" style="margin-top:28px">
          <article class="card reveal">
            <div class="thumb"></div>
            <div class="content">
              <h3>Luxury Brand Launch</h3>
              <p>Minimal, cinematic, polished presentation built to increase trust and boost lead quality.</p>
            </div>
          </article>
          <article class="card reveal">
            <div class="thumb"></div>
            <div class="content">
              <h3>Modern Agency Site</h3>
              <p>Bold headline systems, service architecture, and CTA placement built for conversion.</p>
            </div>
          </article>
          <article class="card reveal">
            <div class="thumb"></div>
            <div class="content">
              <h3>High-End SaaS Experience</h3>
              <p>Premium gradients, visual hierarchy, and a strong product narrative that feels enterprise-ready.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container grid pricing" id="pricing">
        <article class="card reveal">
          <span class="eyebrow">Starter</span>
          <div class="price">$900 <small>/ project</small></div>
          <p>Perfect for a polished brochure site with premium presentation.</p>
          <ul class="list">
            <li>Single landing page</li>
            <li>Modern premium styling</li>
            <li>Contact section</li>
            <li>Mobile responsive</li>
          </ul>
          <a href="#contact" class="btn btn-secondary" style="width:100%">Choose Starter</a>
        </article>

        <article class="card featured reveal">
          <span class="eyebrow">Professional</span>
          <div class="price">$2,500 <small>/ project</small></div>
          <p>Best for agencies, personal brands, and service businesses that want a strong premium look.</p>
          <ul class="list">
            <li>Multi-section website</li>
            <li>Premium animations</li>
            <li>Pricing and FAQ</li>
            <li>Conversion-focused layout</li>
          </ul>
          <a href="#contact" class="btn btn-primary" style="width:100%">Choose Professional</a>
        </article>

        <article class="card reveal">
          <span class="eyebrow">Signature</span>
          <div class="price">$5,000 <small>/ project</small></div>
          <p>For brands that want a tailored, high-end digital identity with a sharper competitive edge.</p>
          <ul class="list">
            <li>Custom sections</li>
            <li>Brand-specific styling</li>
            <li>Advanced storytelling</li>
            <li>Priority revisions</li>
          </ul>
          <a href="#contact" class="btn btn-secondary" style="width:100%">Choose Signature</a>
        </article>
      </div>
    </section>

    <section class="section">
      <div class="container grid testimonials">
        <article class="card reveal">
          <div class="quote">“The site immediately felt more premium. Clients mentioned the design before we even pitched them.”</div>
          <div class="person">— Jordan, Creative Agency Founder</div>
        </article>
        <article class="card reveal">
          <div class="quote">“This looked like a custom luxury build, but it was simple enough to launch without a developer stack.”</div>
          <div class="person">— Alexis, Consultant</div>
        </article>
        <article class="card reveal">
          <div class="quote">“Clean, modern, expensive-looking, and actually easy to edit. Exactly what we needed.”</div>
          <div class="person">— Taylor, Brand Director</div>
        </article>
      </div>
    </section>

    <section class="section" id="faq">
      <div class="container faq reveal">
        <span class="eyebrow">FAQ</span>
        <h2 style="font-size:clamp(30px,4vw,52px);line-height:1.05;margin:18px 0 14px">A few things that usually trip people up.</h2>

        <details open>
          <summary>Why did the old version show code on the page?</summary>
          <p>That usually happens when code is pasted into a visual editor, a CMS text block, or saved with the wrong file extension. This needs to be saved as <strong>index.html</strong> and opened directly in a browser.</p>
        </details>

        <details>
          <summary>Can I use this with GitHub Pages?</summary>
          <p>Yes. Put <strong>index.html</strong> in the root of your repository and publish the repo with GitHub Pages. Since all styling and JavaScript are inside the file, there are no missing asset links to break.</p>
        </details>

        <details>
          <summary>Can I split it into separate files later?</summary>
          <p>Yes. Once you confirm this works, I can split the CSS and JavaScript into separate <strong>style.css</strong> and <strong>script.js</strong> files.</p>
        </details>
      </div>
    </section>

    <section class="section">
      <div class="container card cta reveal" id="contact">
        <div class="inner">
          <span class="eyebrow">Contact</span>
          <h2 style="font-size:clamp(32px,4.5vw,58px);line-height:1.04;margin:18px 0 14px">Ready to make your website look premium?</h2>
          <p style="color:var(--muted);max-width:760px;margin:0 auto 24px;line-height:1.8">
            Replace this section with your own email, phone number, booking link, or contact form embed.
          </p>
          <div class="hero-actions" style="justify-content:center">
            <a href="mailto:hello@example.com" class="btn btn-primary">Email Me</a>
            <a href="tel:+12225551234" class="btn btn-secondary">Call Now</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container footer-row">
      <div>© 2026 Northstar Studio. All rights reserved.</div>
      <div>Built as a single-file HTML website for easy launch.</div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('menuBtn');
    const navList = document.getElementById('navList');

    menuBtn.addEventListener('click', () => {
      navList.classList.toggle('open');
    });

    navList.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => navList.classList.remove('open'));
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>
</body>
</html>
