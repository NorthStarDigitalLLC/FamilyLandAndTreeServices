<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Hot Headz Southern Foods</title>
  <meta name="description" content="Hot Headz Southern Foods in DeRidder, Louisiana.">
  <style>
    :root{--bg:#0d0b09;--bg2:#18120e;--paper:#f6efe5;--text:#1a1612;--accent:#b9562a;--accent2:#d08b44;--muted:#5f554a;--card:#fff9f3;--shadow:0 18px 50px rgba(0,0,0,.18);--r:24px;--max:1150px}
    *{box-sizing:border-box} html{scroll-behavior:smooth} body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:linear-gradient(180deg,var(--bg),var(--bg2));color:#f7f2ec}
    a{text-decoration:none;color:inherit} .container{width:min(var(--max),calc(100% - 28px));margin:auto}
    header{position:sticky;top:0;z-index:50;background:rgba(9,7,6,.72);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,.08)}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:16px;min-height:72px}.brand{font-weight:900;letter-spacing:.02em}.navlinks{display:flex;gap:10px;flex-wrap:wrap}.navlinks a{padding:10px 14px;border-radius:999px;color:rgba(255,255,255,.8)}.navlinks a:hover{background:rgba(255,255,255,.08)}
    .btn{display:inline-flex;align-items:center;justify-content:center;padding:13px 18px;border-radius:999px;font-weight:800}.btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff}.btn.secondary{border:1px solid rgba(255,255,255,.14)}
    .hero{padding:64px 0 30px}.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:24px}.panel{background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.04));border:1px solid rgba(255,255,255,.1);border-radius:28px;box-shadow:0 25px 70px rgba(0,0,0,.28)}
    .hero-copy{padding:40px;display:flex;flex-direction:column;justify-content:center;min-height:520px}.eyebrow{display:inline-block;padding:8px 14px;border-radius:999px;background:rgba(208,139,68,.15);border:1px solid rgba(208,139,68,.25);color:#ffd8ad;font-weight:800;margin-bottom:16px} h1{font-size:clamp(3rem,7vw,5.8rem);line-height:.95;margin:0 0 14px;letter-spacing:-.04em} .sub{font-size:1.08rem;color:rgba(255,255,255,.82);max-width:58ch}
    .meta{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:28px}.meta .card{padding:18px;border-radius:20px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08)} .meta span{display:block;color:rgba(255,255,255,.72);font-size:.92rem}.meta strong{display:block;margin-top:6px}
    .photo{padding:14px;display:grid;grid-template-rows:1.3fr 1fr;gap:14px;min-height:520px}.photo .main,.stack div{border-radius:22px;background-size:cover;background-position:center}.stack{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    section{padding:24px 0}.section-head{display:flex;justify-content:space-between;gap:16px;align-items:end;margin-bottom:16px}.section-head h2{margin:0;font-size:clamp(2rem,4vw,3rem);letter-spacing:-.03em}.section-head p{margin:0;color:rgba(255,255,255,.75);max-width:62ch}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.card{padding:24px;border-radius:24px;background:var(--card);color:var(--text);box-shadow:var(--shadow)} .card p,.card li{color:var(--muted)} .icon{width:52px;height:52px;border-radius:16px;display:grid;place-items:center;background:#f1dfcb;margin-bottom:16px;font-size:1.4rem}
    .menugrid,.infogrid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}.banner{padding:28px;border-radius:28px;background:linear-gradient(135deg,rgba(185,86,42,.2),rgba(208,139,68,.18));border:1px solid rgba(255,255,255,.12)} footer{padding:28px 0 44px;color:rgba(255,255,255,.72)}
    @media (max-width:980px){.hero-grid,.cards,.menugrid,.infogrid,.meta{grid-template-columns:1fr}.hero-copy,.photo{min-height:auto}.nav{flex-direction:column;align-items:flex-start;padding:12px 0}}
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <a href="/" class="brand">Hot Headz Southern Foods</a>
      <nav class="navlinks"><a href="#home">Home</a><a href="/menu/">Menu</a><a href="#delivery">Delivery</a><a href="#about">About</a><a href="#contact">Contact</a></nav>
      <a class="btn primary" href="tel:+13372211035">Call to Order</a>
    </div>
  </header>
  <main>
    <section class="hero" id="home">
      <div class="container hero-grid">
        <div class="panel hero-copy">
          <div class="eyebrow">Breakfast & Lunch • Cafeteria-Style • Made From Scratch</div>
          <h1>Hot Headz<br>Southern Foods</h1>
          <p class="sub">Home-style Southern cooking, made fresh daily. Visit us in DeRidder for breakfast classics, hearty lunch plates, and fresh comfort food served cafeteria-style.</p>
          <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:24px"><a class="btn primary" href="/menu/">View Today’s Menu</a><a class="btn secondary" href="#contact">Find Us</a></div>
          <div class="meta">
            <div class="card"><span>Location</span><strong>DeRidder, LA</strong></div>
            <div class="card"><span>Service</span><strong>Dine-In • Carry-Out • Delivery</strong></div>
            <div class="card"><span>Delivery</span><strong>10 plates+ within 10 miles</strong></div>
          </div>
        </div>
        <div class="panel photo" aria-label="Restaurant image gallery">
          <div class="main" style="background-image:url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1200&q=80')"></div>
          <div class="stack">
            <div style="background-image:url('https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=900&q=80')"></div>
            <div style="background-image:url('https://images.unsplash.com/photo-1525351484163-7529414344d8?auto=format&fit=crop&w=900&q=80')"></div>
          </div>
        </div>
      </div>
    </section>
    <section>
      <div class="container">
        <div class="section-head"><h2>Fresh. Filling. From scratch.</h2><p>Fast and friendly cafeteria-style service with generous portions and classic Southern flavor.</p></div>
        <div class="cards">
          <article class="card"><div class="icon">☀️</div><h3>Breakfast favorites</h3><p>Start the day with breakfast plates, biscuits, gravy, eggs, and classic morning comfort food.</p></article>
          <article class="card"><div class="icon">🍽️</div><h3>Daily lunch menu</h3><p>Check the full menu page for lunch plates, salad bar, drinks, dessert, and rotating specials.</p></article>
          <article class="card"><div class="icon">📞</div><h3>Quick ordering</h3><p>Call ahead for carry-out or ask about delivery for large orders within the local delivery radius.</p></article>
        </div>
      </div>
    </section>
    <section id="delivery"><div class="container banner"><h2 style="margin-top:0">Delivery available for large orders</h2><p style="color:rgba(255,255,255,.8)">Delivery is available for 10+ orders within a 10-mile radius.</p><a class="btn primary" href="tel:+13372211035">Order by Phone</a></div></section>
    <section id="about">
      <div class="container menugrid">
        <article class="card"><h3>Menu highlights</h3><ul><li>Breakfast plates</li><li>Daily lunch plates</li><li>Salad bar</li><li>Drinks</li><li>Dessert</li><li>Seasonal crawfish hours</li></ul></article>
        <article class="card" id="contact"><h3>Location & hours</h3><p><strong>Address:</strong> 2741 US-190, DeRidder, LA 70634</p><p><strong>Phone:</strong> <a href="tel:+13372211035">(337) 221-1035</a></p><p><strong>Hours:</strong><br>Mon–Fri 5:30 AM – 2:00 PM<br>Saturday 6:00 AM – 2:00 PM<br>Sunday 7:00 AM – 3:00 PM</p><p><strong>Crawfish Hours:</strong><br>4:00 PM – 8:00 PM</p><p><a href="https://maps.google.com/?q=2741+US-190+DeRidder+LA+70634" target="_blank" rel="noreferrer">Get Directions</a></p></article>
      </div>
    </section>
  </main>
  <footer><div class="container" style="display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap"><div>© <span id="year"></span> HotHeadzSouthernFoods</div><div>GitHub Pages static export</div></div></footer>
  <script>document.getElementById('year').textContent=new Date().getFullYear()</script>
</body>
</html>
