<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NovaSite | GitHub Pages Website</title>
  <meta name="description" content="A responsive, GitHub Pages-ready website template." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container nav">
      <a href="#home" class="logo">NovaSite</a>

      <button class="nav-toggle" id="navToggle" aria-label="Open navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="site-nav" id="siteNav">
        <a href="#home">Home</a>
        <a href="#features">Features</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">🌙</button>
      </nav>
    </div>
  </header>

  <main id="home">
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">GitHub Pages Ready</p>
          <h1>Launch a clean, modern website in minutes.</h1>
          <p class="hero-text">
            This fully functional static website template is responsive, accessible, and easy to deploy on GitHub Pages.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#contact">Get Started</a>
            <a class="btn btn-secondary" href="#features">See Features</a>
          </div>
        </div>

        <div class="hero-card">
          <div class="status-pill">Live • Fast • Responsive</div>
          <h2>Everything you need</h2>
          <ul class="check-list">
            <li>Responsive layout</li>
            <li>Dark mode support</li>
            <li>Mobile navigation</li>
            <li>Client-side form validation</li>
            <li>Easy GitHub Pages deployment</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="features" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Features</p>
          <h2>Built for real use</h2>
          <p>A strong starting point for portfolios, startups, product sites, or business landing pages.</p>
        </div>

        <div class="cards">
          <article class="card">
            <h3>Responsive Design</h3>
            <p>Looks great on desktop, tablet, and mobile without extra setup.</p>
          </article>
          <article class="card">
            <h3>Fast Loading</h3>
            <p>Simple static files that work well with GitHub Pages hosting.</p>
          </article>
          <article class="card">
            <h3>Easy to Customize</h3>
            <p>Clean HTML, CSS, and JavaScript that you can edit in any code editor.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="about" class="section alt">
      <div class="container about-grid">
        <div>
          <p class="eyebrow">About</p>
          <h2>Made for quick deployment</h2>
          <p>
            This template is intentionally lightweight. You can rename the brand, update the text, swap colors,
            and publish it directly from a GitHub repository using GitHub Pages.
          </p>
          <p>
            It includes a polished layout, sticky navigation, dark mode, and JavaScript enhancements that work out of the box.
          </p>
        </div>

        <div class="stats">
          <div class="stat">
            <strong>100%</strong>
            <span>Static hosting friendly</span>
          </div>
          <div class="stat">
            <strong>3 files</strong>
            <span>Core site structure</span>
          </div>
          <div class="stat">
            <strong>0 build tools</strong>
            <span>Just upload and publish</span>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Contact</p>
          <h2>Send a message</h2>
          <p>This form validates on the client side. For live email delivery, connect a backend or form service later.</p>
        </div>

        <form id="contactForm" class="contact-form" novalidate>
          <div class="form-row">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" placeholder="Your name" required />
            <small class="error" data-error-for="name"></small>
          </div>

          <div class="form-row">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="you@example.com" required />
            <small class="error" data-error-for="email"></small>
          </div>

          <div class="form-row">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Write your message..." required></textarea>
            <small class="error" data-error-for="message"></small>
          </div>

          <button type="submit" class="btn btn-primary">Submit</button>
          <p id="formStatus" class="form-status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-wrap">
      <p>© <span id="year"></span> NovaSite. Built for GitHub Pages.</p>
      <a href="#home">Back to top ↑</a>
    </div>
  </footer>

  <script src="script.js"></script>
</body>
</html>
